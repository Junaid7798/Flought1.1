#!/usr/bin/env sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run lint-staged on staged files
echo "📝 Running lint-staged..."
npx lint-staged

# Full type check to catch cross-file issues
echo "🔧 Running full type check..."
npm run check

if [ $? -ne 0 ]; then
    echo "❌ Type check failed. Fix errors before committing."
    exit 1
fi

# Note: Full build is skipped here to keep hook fast (25s+).
# CI will run the full build on every push/PR.

echo "✅ Type check passed! (Full build will run in CI)"
